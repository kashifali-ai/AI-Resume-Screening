# Copy to .env and fill in your Gemini key.

# --- LLM (Google Gemini) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash          # e.g. gemini-2.5-flash, gemini-2.0-flash
LLM_PROVIDER=gemini

# --- Offline mock mode ---
# true  -> deterministic rule-based extraction, NO Gemini calls / quota / key.
# false -> use Gemini exactly as before. Great for tests, demos, and CI.
MOCK_LLM=false

# --- Embeddings (sentence-transformers, runs locally) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SIM_THRESHOLD=0.55

# --- Scoring / verdict ---
# The role, required skills, and experience window all come from the pasted job
# description — nothing role-specific is configured here.
FIT_THRESHOLD=60
REQUIRED_SKILL_WEIGHT=1.0
PREFERRED_SKILL_WEIGHT=0.5
OVERQUALIFIED_FACTOR=0.9

# --- I/O ---
MAX_JD_CHARS=20000

LOG_LEVEL=INFO
