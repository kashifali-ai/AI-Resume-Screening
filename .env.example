# Copy to .env and fill in your Gemini key.

# --- LLM (Google Gemini) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash          # e.g. gemini-2.5-flash, gemini-2.0-flash
LLM_PROVIDER=gemini

# --- Embeddings (sentence-transformers, runs locally) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SIM_THRESHOLD=0.55

# --- Scoring / verdict ---
FIT_THRESHOLD=60
MIN_EXPERIENCE=1
MAX_EXPERIENCE=5

LOG_LEVEL=INFO
